rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNonAnonymous() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isOwner(userId) {
      return isNonAnonymous() && request.auth.uid == userId;
    }

    function currentUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function countersDocPath() {
      return /databases/$(database)/documents/meta/counters;
    }

    function actorHasRootRole() {
      return isNonAnonymous()
        && exists(currentUserDocPath())
        && get(currentUserDocPath()).data.roles is list
        && get(currentUserDocPath()).data.roles.hasAny(["root"]);
    }

    function validShortString(value, maxSize) {
      return value == null || (value is string && value.size() <= maxSize);
    }

    function validStringList(value, maxSize) {
      return value is list && value.size() <= maxSize;
    }

    function validPresence(value) {
      return value is map
        && value.keys().hasOnly(["status", "isOnline", "currentPath", "lastSeenAt"])
        && (!("status" in value) || value.status is string)
        && (!("isOnline" in value) || value.isOnline is bool)
        && (!("currentPath" in value) || value.currentPath == null || value.currentPath is string)
        && (!("lastSeenAt" in value) || value.lastSeenAt == null || value.lastSeenAt is string);
    }

    function validRoleList(value) {
      return value is list
        && value.size() > 0
        && value.size() <= 5
        && value.hasOnly(["root", "co-owner", "sponsor", "moderator", "user"]);
    }

    function validUserDoc(userId) {
      return request.resource.data.uid == userId
        && validShortString(request.resource.data.email, 320)
        && validShortString(request.resource.data.login, 24)
        && validShortString(request.resource.data.loginLower, 24)
        && validShortString(request.resource.data.displayName, 96)
        && validShortString(request.resource.data.photoURL, 1000000)
        && validRoleList(request.resource.data.roles)
        && validStringList(request.resource.data.providerIds, 12)
        && validStringList(request.resource.data.loginHistory, 12)
        && validStringList(request.resource.data.visitHistory, 12)
        && validPresence(request.resource.data.presence)
        && validShortString(request.resource.data.creationTime, 64)
        && validShortString(request.resource.data.lastSignInTime, 64)
        && validShortString(request.resource.data.updatedAt, 64)
        && request.resource.data.profileId is int
        && request.resource.data.profileId > 0;
    }

    function validProfileCounterReservation() {
      return request.resource.data.profileId is int
        && request.resource.data.profileId > 0
        && getAfter(countersDocPath()).data.profileCount is int
        && getAfter(countersDocPath()).data.profileCount == request.resource.data.profileId
        && (
          !exists(countersDocPath())
            ? request.resource.data.profileId == 1
            : request.resource.data.profileId == get(countersDocPath()).data.profileCount + 1
        );
    }

    function ownerKeepsProtectedFields() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.profileId == resource.data.profileId
        && request.resource.data.roles == resource.data.roles
        && request.resource.data.creationTime == resource.data.creationTime;
    }

    function ownerCanClaimFirstProfileId() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.roles == resource.data.roles
        && request.resource.data.creationTime == resource.data.creationTime
        && (!(resource.data.profileId is int) || resource.data.profileId == null)
        && validProfileCounterReservation();
    }

    function rootRoleUpdateOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(["roles", "updatedAt"])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.profileId == resource.data.profileId
        && request.resource.data.creationTime == resource.data.creationTime
        && validRoleList(request.resource.data.roles);
    }

    function validProfileComment() {
      return request.resource.data.keys().hasOnly([
          "profileId",
          "authorUid",
          "authorProfileId",
          "authorName",
          "message",
          "createdAt"
        ])
        && request.resource.data.profileId is int
        && request.resource.data.profileId > 0
        && request.resource.data.authorUid == request.auth.uid
        && (
          request.resource.data.authorProfileId == null
            || (request.resource.data.authorProfileId is int && request.resource.data.authorProfileId > 0)
        )
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 48
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 280
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() > 0
        && request.resource.data.createdAt.size() <= 64;
    }

    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && validUserDoc(userId)
        && request.resource.data.roles == ["user"]
        && validProfileCounterReservation();

      allow update: if (isOwner(userId) && validUserDoc(userId) && ownerKeepsProtectedFields())
        || (isOwner(userId) && validUserDoc(userId) && ownerCanClaimFirstProfileId())
        || (actorHasRootRole() && validUserDoc(userId) && rootRoleUpdateOnly());

      allow delete: if false;
    }

    match /meta/counters {
      allow get: if isNonAnonymous();
      allow list: if false;

      allow create: if isNonAnonymous()
        && request.resource.data.keys().hasOnly(["profileCount"])
        && request.resource.data.profileCount is int
        && request.resource.data.profileCount == 1
        && getAfter(currentUserDocPath()).data.uid == request.auth.uid
        && getAfter(currentUserDocPath()).data.profileId == request.resource.data.profileCount;

      allow update: if isNonAnonymous()
        && request.resource.data.keys().hasOnly(["profileCount"])
        && resource.data.profileCount is int
        && request.resource.data.profileCount is int
        && request.resource.data.profileCount == resource.data.profileCount + 1
        && getAfter(currentUserDocPath()).data.uid == request.auth.uid
        && getAfter(currentUserDocPath()).data.profileId == request.resource.data.profileCount
        && (
          !exists(currentUserDocPath())
            || !(get(currentUserDocPath()).data.profileId is int)
            || get(currentUserDocPath()).data.profileId == null
        );

      allow delete: if false;
    }

    match /profileComments/{commentId} {
      allow read: if true;
      allow create: if isNonAnonymous() && validProfileComment();
      allow update, delete: if false;
    }
  }
}
